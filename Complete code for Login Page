<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Aurora Auth</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
/* ============================================
   1. RESET & CSS VARIABLES
   ============================================ */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg-primary:#09090B;--bg-secondary:#111827;--bg-tertiary:#1E293B;
  --accent-purple:#8B5CF6;--accent-pink:#EC4899;--accent-blue:#60A5FA;--accent-cyan:#22D3EE;--accent-violet:#A855F7;
  --glass:rgba(255,255,255,.08);--glass-strong:rgba(255,255,255,.12);
  --border:rgba(255,255,255,.15);--border-focus:rgba(139,92,246,.6);
  --text-primary:#FFFFFF;--text-secondary:#CBD5E1;--text-muted:#64748B;
  --error:#F87171;--success:#34D399;--warning:#FBBF24;
  --card-bg:rgba(17,24,39,.75);--card-blur:20px;
  --radius:24px;--radius-sm:12px;--radius-xs:8px;
  --font:'Outfit',system-ui,sans-serif;
  --bunny-speed:25s;
}
html{font-size:16px;scroll-behavior:smooth}
body{
  font-family:var(--font);background:var(--bg-primary);color:var(--text-primary);
  min-height:100vh;overflow-x:hidden;display:flex;flex-direction:column;align-items:center;justify-content:center;
  position:relative;
}
a{color:var(--accent-purple);text-decoration:none;position:relative}
a::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:1.5px;background:var(--accent-purple);transition:width .3s ease}
a:hover::after{width:100%}
input,button{font-family:var(--font);outline:none;border:none}
button{cursor:pointer}
:focus-visible{outline:2px solid var(--accent-purple);outline-offset:2px;border-radius:4px}
::selection{background:var(--accent-purple);color:#fff}

/* ============================================
   2. BACKGROUND ATMOSPHERE
   ============================================ */
#bg{position:fixed;inset:0;z-index:0;overflow:hidden;pointer-events:none}
.aurora{position:absolute;border-radius:50%;filter:blur(80px);opacity:.35;will-change:transform}
.aurora-1{width:600px;height:400px;background:linear-gradient(135deg,var(--accent-purple),var(--accent-pink));top:-10%;left:-5%;animation:aurora-move1 18s ease-in-out infinite}
.aurora-2{width:500px;height:350px;background:linear-gradient(135deg,var(--accent-cyan),var(--accent-blue));top:20%;right:-10%;animation:aurora-move2 22s ease-in-out infinite}
.aurora-3{width:450px;height:300px;background:linear-gradient(135deg,var(--accent-pink),var(--accent-violet));bottom:-5%;left:30%;animation:aurora-move3 20s ease-in-out infinite}
@keyframes aurora-move1{0%,100%{transform:translate(0,0) scale(1)}25%{transform:translate(80px,40px) scale(1.1)}50%{transform:translate(40px,80px) scale(.95)}75%{transform:translate(-30px,30px) scale(1.05)}}
@keyframes aurora-move2{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(-60px,50px) scale(1.08)}66%{transform:translate(-30px,-40px) scale(.92)}}
@keyframes aurora-move3{0%,100%{transform:translate(0,0) rotate(0deg)}50%{transform:translate(60px,-30px) rotate(5deg)}}

.blob{position:absolute;border-radius:50%;filter:blur(100px);opacity:.2;will-change:transform}
.blob-1{width:300px;height:300px;background:var(--accent-purple);top:60%;left:10%;animation:blob-drift 25s ease-in-out infinite}
.blob-2{width:250px;height:250px;background:var(--accent-cyan);top:10%;right:20%;animation:blob-drift 30s ease-in-out infinite reverse}
.blob-3{width:200px;height:200px;background:var(--accent-pink);bottom:20%;right:5%;animation:blob-drift 28s ease-in-out infinite 5s}
@keyframes blob-drift{0%,100%{transform:translate(0,0)}25%{transform:translate(30px,-40px)}50%{transform:translate(-20px,30px)}75%{transform:translate(40px,20px)}}

/* Stars */
.star{position:absolute;border-radius:50%;background:#fff;will-change:opacity}
@keyframes twinkle{0%,100%{opacity:.2;transform:scale(1)}50%{opacity:1;transform:scale(1.3)}}

/* Clouds */
.cloud{position:absolute;background:rgba(255,255,255,.03);border-radius:50%;filter:blur(30px);opacity:0;transition:opacity 1.5s}
body.light-mode .cloud{opacity:1;background:rgba(255,255,255,.6)}
.cloud-1{width:300px;height:80px;top:8%;left:-5%;animation:cloud-drift 40s linear infinite}
.cloud-2{width:250px;height:60px;top:15%;left:30%;animation:cloud-drift 55s linear infinite 10s}
.cloud-3{width:350px;height:90px;top:5%;left:60%;animation:cloud-drift 45s linear infinite 20s}
@keyframes cloud-drift{0%{transform:translateX(-100%)}100%{transform:translateX(calc(100vw + 100%))}}

/* Floating particles */
.particle{position:absolute;border-radius:50%;pointer-events:none;will-change:transform,opacity}
@keyframes float-up{0%{transform:translateY(0) scale(1);opacity:0}10%{opacity:1}90%{opacity:.5}100%{transform:translateY(-100vh) scale(0);opacity:0}}

/* ============================================
   3. HEADER / LOGO
   ============================================ */
.page-header{
  position:relative;z-index:5;text-align:center;margin-bottom:40px;
  opacity:0;transform:translateY(-30px);transition:all .8s cubic-bezier(.16,1,.3,1);
}
.page-header.visible{opacity:1;transform:translateY(0)}
.logo{font-size:2.4rem;font-weight:800;letter-spacing:-1px;background:linear-gradient(135deg,var(--accent-purple),var(--accent-pink),var(--accent-cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.subtitle{font-size:.95rem;color:var(--text-secondary);font-weight:300;margin-top:6px;letter-spacing:.5px}

/* ============================================
   4. CARDS CONTAINER
   ============================================ */
.cards-container{
  position:relative;z-index:5;display:flex;gap:32px;align-items:flex-start;
  opacity:0;transform:translateY(40px);transition:all 1s cubic-bezier(.16,1,.3,1) .3s;
}
.cards-container.visible{opacity:1;transform:translateY(0)}

/* ============================================
   5. ANIMATED BORDER WRAPPER
   ============================================ */
.card-outer{
  position:relative;padding:2px;border-radius:var(--radius);overflow:hidden;
  opacity:0;transform:translateY(40px) scale(.95);transition:all .9s cubic-bezier(.16,1,.3,1);
}
.card-outer.visible{opacity:1;transform:translateY(0) scale(1)}
.card-outer:nth-child(2){transition-delay:.5s}
.card-outer::before{
  content:'';position:absolute;inset:-80%;
  background:conic-gradient(from 0deg,transparent,var(--accent-purple),var(--accent-pink),var(--accent-blue),var(--accent-cyan),transparent);
  animation:spin-border 6s linear infinite;
  opacity:.7;
}
.card-outer::after{
  content:'';position:absolute;inset:0;border-radius:var(--radius);
  box-shadow:0 0 30px rgba(139,92,246,.15),0 0 60px rgba(139,92,246,.05);
  animation:glow-pulse 3s ease-in-out infinite;pointer-events:none;
}
@keyframes spin-border{to{transform:rotate(360deg)}}
@keyframes glow-pulse{0%,100%{box-shadow:0 0 30px rgba(139,92,246,.15),0 0 60px rgba(139,92,246,.05)}50%{box-shadow:0 0 50px rgba(139,92,246,.25),0 0 100px rgba(139,92,246,.1)}}

/* Rainbow mode easter egg */
body.rainbow-mode .card-outer::before{
  background:conic-gradient(from 0deg,#ff0000,#ff8800,#ffff00,#00ff00,#0088ff,#8800ff,#ff0000);
  animation-duration:3s;opacity:1;
}

/* ============================================
   6. GLASS CARD
   ============================================ */
.card{
  position:relative;width:420px;max-width:90vw;
  background:var(--card-bg);backdrop-filter:blur(var(--card-blur));-webkit-backdrop-filter:blur(var(--card-blur));
  border-radius:calc(var(--radius) - 2px);padding:36px 32px;z-index:1;
  animation:card-float 6s ease-in-out infinite;
  transition:transform .15s ease-out;
}
@keyframes card-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}

/* Glass reflection */
.card::before{
  content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;
  background:linear-gradient(135deg,transparent 42%,rgba(255,255,255,.04) 46%,rgba(255,255,255,.08) 50%,rgba(255,255,255,.04) 54%,transparent 58%);
  pointer-events:none;z-index:0;
}
/* Noise overlay */
.card::after{
  content:'';position:absolute;inset:0;border-radius:calc(var(--radius) - 2px);
  opacity:.035;pointer-events:none;z-index:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size:128px 128px;
}
.card>*{position:relative;z-index:1}

/* Inner glow */
.card-inner-glow{
  position:absolute;inset:0;border-radius:calc(var(--radius) - 2px);
  box-shadow:inset 0 1px 0 rgba(255,255,255,.1),inset 0 -1px 0 rgba(0,0,0,.2);
  pointer-events:none;z-index:2;
}

/* ============================================
   7. TYPOGRAPHY IN CARDS
   ============================================ */
.card-heading{font-size:1.65rem;font-weight:700;margin-bottom:4px;min-height:2.2rem}
.card-heading .cursor{display:inline-block;width:2px;height:1.4rem;background:var(--accent-purple);margin-left:2px;vertical-align:middle;animation:cursor-blink 1s step-end infinite}
@keyframes cursor-blink{0%,100%{opacity:1}50%{opacity:0}}
.card-subtitle{font-size:.875rem;color:var(--text-secondary);font-weight:300;margin-bottom:28px}

/* ============================================
   8. FORM INPUTS
   ============================================ */
.input-group{position:relative;margin-bottom:20px}
.input-group .input-icon{
  position:absolute;left:14px;top:50%;transform:translateY(-50%);
  width:18px;height:18px;color:var(--text-muted);transition:all .3s;pointer-events:none;z-index:2;
}
.input-group .input-icon svg{width:100%;height:100%;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.input-group:focus-within .input-icon{color:var(--accent-purple);transform:translateY(-50%) rotate(-10deg) scale(1.1)}

.input-field{
  width:100%;height:52px;padding:16px 14px 8px 42px;
  background:rgba(255,255,255,.05);border:1.5px solid var(--border);border-radius:var(--radius-xs);
  color:var(--text-primary);font-size:.9rem;font-weight:400;
  transition:all .3s cubic-bezier(.4,0,.2,1);
}
.input-field::placeholder{color:transparent}
.input-field:hover{border-color:rgba(255,255,255,.25);background:rgba(255,255,255,.07)}
.input-field:focus{border-color:var(--border-focus);background:rgba(255,255,255,.08);box-shadow:0 0 0 3px rgba(139,92,246,.15),0 0 20px rgba(139,92,246,.08)}

.float-label{
  position:absolute;left:42px;top:50%;transform:translateY(-50%);
  font-size:.9rem;color:var(--text-muted);pointer-events:none;
  transition:all .25s cubic-bezier(.4,0,.2,1);transform-origin:left center;
}
.input-field:focus~.float-label,.input-field:not(:placeholder-shown)~.float-label{
  top:12px;transform:translateY(0) scale(.75);color:var(--accent-purple);
}

/* Validation states */
.input-group.error .input-field{border-color:var(--error);box-shadow:0 0 0 3px rgba(248,113,113,.15)}
.input-group.error .float-label{color:var(--error)!important}
.input-group.success .input-field{border-color:var(--success);box-shadow:0 0 0 3px rgba(52,211,153,.15)}
.input-group.success .float-label{color:var(--success)!important}
.input-group.shake{animation:shake .5s ease-in-out}
@keyframes shake{0%,100%{transform:translateX(0)}20%{transform:translateX(-8px)}40%{transform:translateX(8px)}60%{transform:translateX(-5px)}80%{transform:translateX(5px)}}

.validation-msg{font-size:.75rem;margin-top:4px;padding-left:4px;opacity:0;transform:translateY(-5px);transition:all .3s}
.input-group.error .validation-msg{opacity:1;transform:translateY(0);color:var(--error)}
.input-group.success .validation-msg{opacity:1;transform:translateY(0);color:var(--success)}

/* ============================================
   9. PASSWORD FIELD
   ============================================ */
.pwd-toggle{
  position:absolute;right:12px;top:50%;transform:translateY(-50%);
  width:32px;height:32px;display:flex;align-items:center;justify-content:center;
  background:transparent;border-radius:50%;cursor:pointer;z-index:2;
  transition:all .2s;color:var(--text-muted);
}
.pwd-toggle:hover{color:var(--text-primary);background:rgba(255,255,255,.08)}
.pwd-toggle svg{width:18px;height:18px;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.pwd-toggle.wink .eye-open{animation:wink .3s ease}
@keyframes wink{0%{transform:scaleY(1)}50%{transform:scaleY(.1)}100%{transform:scaleY(1)}}

/* Password strength meter */
.strength-meter{height:3px;background:rgba(255,255,255,.08);border-radius:3px;margin-top:8px;overflow:hidden;opacity:0;transition:opacity .3s}
.strength-meter.visible{opacity:1}
.strength-bar{height:100%;width:0;border-radius:3px;transition:all .5s cubic-bezier(.4,0,.2,1);background:linear-gradient(90deg,var(--error),var(--warning),var(--success),var(--accent-cyan))}
.strength-label{font-size:.7rem;margin-top:4px;color:var(--text-muted);transition:color .3s;min-height:1em}

/* ============================================
   10. BUTTONS
   ============================================ */
.btn-primary{
  width:100%;height:50px;border-radius:var(--radius-xs);font-size:.95rem;font-weight:600;
  color:#fff;position:relative;overflow:hidden;
  background:linear-gradient(135deg,var(--accent-purple),var(--accent-pink));
  transition:all .3s;letter-spacing:.3px;
}
.btn-primary:hover{box-shadow:0 0 30px rgba(139,92,246,.4),0 0 60px rgba(236,72,153,.2);transform:translateY(-1px)}
.btn-primary:active{transform:translateY(1px) scale(.98)}
.btn-primary .btn-text{position:relative;z-index:1;transition:all .3s}
.btn-primary.loading .btn-text{opacity:0;transform:translateY(-10px)}
.btn-primary .btn-loader{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;opacity:0;transition:all .3s}
.btn-primary.loading .btn-loader{opacity:1}
.spinner{width:22px;height:22px;border:2.5px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

/* Shine sweep */
.btn-primary::before{
  content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.2),transparent);
  transition:none;z-index:1;
}
.btn-primary:hover::before{animation:shine-sweep .8s ease forwards}
@keyframes shine-sweep{to{left:150%}}

/* Ripple */
.ripple{position:absolute;border-radius:50%;background:rgba(255,255,255,.3);transform:scale(0);animation:ripple-out .6s ease-out forwards;pointer-events:none;z-index:1}
@keyframes ripple-out{to{transform:scale(4);opacity:0}}

/* Social buttons */
.social-btns{display:flex;gap:12px;margin-top:16px}
.btn-social{
  flex:1;height:46px;border-radius:var(--radius-xs);display:flex;align-items:center;justify-content:center;gap:8px;
  background:var(--glass);border:1.5px solid var(--border);color:var(--text-primary);
  font-size:.85rem;font-weight:500;transition:all .3s;position:relative;overflow:hidden;
}
.btn-social:hover{border-color:rgba(255,255,255,.3);background:var(--glass-strong);transform:translateY(-1px)}
.btn-social svg{width:18px;height:18px}

/* ============================================
   11. CHECKBOX
   ============================================ */
.checkbox-group{display:flex;align-items:center;gap:10px;margin-bottom:20px;cursor:pointer}
.custom-checkbox{
  width:20px;height:20px;border:1.5px solid var(--border);border-radius:5px;
  display:flex;align-items:center;justify-content:center;transition:all .3s;flex-shrink:0;
  background:rgba(255,255,255,.05);
}
.custom-checkbox svg{width:12px;height:12px;stroke:#fff;stroke-width:3;fill:none;opacity:0;transform:scale(0);transition:all .25s cubic-bezier(.34,1.56,.64,1)}
.checkbox-group.checked .custom-checkbox{background:var(--accent-purple);border-color:var(--accent-purple)}
.checkbox-group.checked .custom-checkbox svg{opacity:1;transform:scale(1)}
.checkbox-group.bounce .custom-checkbox{animation:checkbox-bounce .4s ease}
@keyframes checkbox-bounce{0%{transform:scale(1)}30%{transform:scale(1.3)}60%{transform:scale(.9)}100%{transform:scale(1)}}
.checkbox-label{font-size:.82rem;color:var(--text-secondary);user-select:none}
.checkbox-label a{color:var(--accent-purple)}

/* Remember me & forgot password row */
.form-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
.form-row .checkbox-group{margin-bottom:0}

/* ============================================
   12. DIVIDER
   ============================================ */
.divider{display:flex;align-items:center;gap:12px;margin:20px 0}
.divider-line{flex:1;height:1px;background:var(--border)}
.divider-text{font-size:.75rem;color:var(--text-muted);font-weight:400;white-space:nowrap}

/* ============================================
   13. BUNNY - PURE CSS
   ============================================ */
#bunny{
  position:absolute;width:36px;height:44px;z-index:10;pointer-events:auto;
  transition:filter .3s;cursor:default;
}
#bunny:hover{filter:drop-shadow(0 0 8px rgba(236,72,153,.6))}
.bunny-wrap{position:relative;animation:bunny-breathe 2s ease-in-out infinite}
@keyframes bunny-breathe{0%,100%{transform:scaleY(1)}50%{transform:scaleY(1.04)}}

.bunny-head{
  width:26px;height:24px;background:#fff;border-radius:50% 50% 46% 46%;
  position:relative;margin:0 auto;
}
/* Ears */
.bunny-ear{
  width:9px;height:20px;background:#fff;border-radius:50% 50% 35% 35%;
  position:absolute;top:-16px;
}
.bunny-ear.l{left:3px;transform-origin:bottom center;animation:ear-l 2.5s ease-in-out infinite}
.bunny-ear.r{right:3px;transform-origin:bottom center;animation:ear-r 2.5s ease-in-out infinite .6s}
.bunny-ear-inner{width:5px;height:13px;background:#FBB6CE;border-radius:50%;margin:4px auto 0}
@keyframes ear-l{0%,100%{transform:rotate(0)}50%{transform:rotate(-8deg)}}
@keyframes ear-r{0%,100%{transform:rotate(0)}50%{transform:rotate(8deg)}}

/* Eyes */
.bunny-eye{
  width:5.5px;height:6.5px;background:#1a1a2e;border-radius:50%;
  position:absolute;top:8px;
  animation:bunny-blink 3.5s ease-in-out infinite;
}
.bunny-eye.l{left:4px}.bunny-eye.r{right:4px}
.bunny-shine{width:2px;height:2px;background:#fff;border-radius:50%;position:absolute;top:1.5px;right:1px}
@keyframes bunny-blink{0%,42%,58%,100%{transform:scaleY(1)}50%{transform:scaleY(.1)}}

/* Nose & mouth */
.bunny-nose{
  width:5px;height:3.5px;background:#F472B6;border-radius:50% 50% 50% 50%/30% 30% 70% 70%;
  position:absolute;bottom:6px;left:50%;transform:translateX(-50%);
}
.bunny-mouth{
  width:8px;height:3px;border-bottom:1.5px solid #d4a0a0;border-radius:0 0 50% 50%;
  position:absolute;bottom:3px;left:50%;transform:translateX(-50%);
}

/* Blush */
.bunny-blush{
  width:7px;height:3.5px;background:rgba(251,182,206,.55);border-radius:50%;
  position:absolute;top:14px;
}
.bunny-blush.l{left:0}.bunny-blush.r{right:0}

/* Body */
.bunny-torso{width:22px;height:14px;background:#fff;border-radius:42% 42% 50% 50%;margin:-2px auto 0;position:relative}

/* Feet */
.bunny-foot{
  width:9px;height:5px;background:#fff;border-radius:50%;
  position:absolute;bottom:-1px;
}
.bunny-foot.l{left:0;animation:foot-l .35s ease-in-out infinite}
.bunny-foot.r{right:0;animation:foot-r .35s ease-in-out infinite .175s}
@keyframes foot-l{0%,100%{transform:translateY(0)}50%{transform:translateY(-2px)}}
@keyframes foot-r{0%,100%{transform:translateY(-2px)}50%{transform:translateY(0)}}

/* Tail */
.bunny-tail{width:8px;height:8px;background:#fff;border-radius:50%;position:absolute;bottom:4px;left:-4px;animation:tail-wiggle .8s ease-in-out infinite}
@keyframes tail-wiggle{0%,100%{transform:translate(0,0)}50%{transform:translate(-2px,-1px)}}

/* Shadow */
.bunny-shadow{width:28px;height:5px;background:rgba(0,0,0,.18);border-radius:50%;margin:3px auto 0;animation:shadow-b 2s ease-in-out infinite}
@keyframes shadow-b{0%,100%{transform:scaleX(1);opacity:.18}50%{transform:scaleX(.9);opacity:.12}}

/* Speech bubble */
.bunny-speech{
  position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%) scale(0);
  background:var(--card-bg);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);
  border:1px solid var(--border);border-radius:10px;padding:5px 10px;
  font-size:.7rem;font-weight:500;white-space:nowrap;color:var(--text-primary);
  opacity:0;transition:all .3s cubic-bezier(.34,1.56,.64,1);pointer-events:none;
}
.bunny-speech::after{content:'';position:absolute;top:100%;left:50%;transform:translateX(-50%);border:5px solid transparent;border-top-color:var(--border)}
.bunny-speech.show{opacity:1;transform:translateX(-50%) scale(1)}

/* Heart particles on bunny hover */
.heart-particle{
  position:absolute;font-size:.7rem;pointer-events:none;
  animation:heart-float 1.2s ease-out forwards;
}
@keyframes heart-float{0%{opacity:1;transform:translate(0,0) scale(.5)}100%{opacity:0;transform:translate(var(--hx),-50px) scale(1.2) rotate(var(--hr))}}

/* Mini bunnies for easter egg */
.mini-bunny{position:fixed;z-index:100;pointer-events:none}
.mini-bunny .mb-body{width:12px;height:14px;background:#fff;border-radius:50% 50% 40% 40%;position:relative}
.mini-bunny .mb-ear{width:4px;height:9px;background:#fff;border-radius:50%;position:absolute;top:-6px}
.mini-bunny .mb-ear.l{left:1px}.mini-bunny .mb-ear.r{right:1px}
.mini-bunny .mb-eye{width:2px;height:2.5px;background:#1a1a2e;border-radius:50%;position:absolute;top:4px}
.mini-bunny .mb-eye.l{left:2px}.mini-bunny .mb-eye.r{right:2px}

/* ============================================
   14. THEME TOGGLE
   ============================================ */
#theme-toggle{
  position:fixed;top:24px;right:80px;z-index:50;width:52px;height:28px;
  border-radius:14px;background:var(--glass);border:1.5px solid var(--border);
  cursor:pointer;transition:all .5s;overflow:hidden;
}
#theme-toggle:hover{border-color:rgba(255,255,255,.3)}
.toggle-knob{
  position:absolute;top:3px;left:3px;width:20px;height:20px;border-radius:50%;
  background:var(--accent-purple);transition:all .5s cubic-bezier(.68,-.55,.27,1.55);
  display:flex;align-items:center;justify-content:center;
}
.toggle-knob svg{width:12px;height:12px;fill:#fff;transition:all .5s}
body.light-mode #theme-toggle{background:rgba(251,191,36,.2);border-color:rgba(251,191,36,.4)}
body.light-mode .toggle-knob{left:27px;background:#FBBF24}
body.light-mode .toggle-knob .moon{opacity:0;transform:rotate(180deg) scale(0)}
body.light-mode .toggle-knob .sun{opacity:1;transform:rotate(0) scale(1)}
.toggle-knob .sun{position:absolute;opacity:0;transform:rotate(-180deg) scale(0)}

/* ============================================
   15. SETTINGS PANEL
   ============================================ */
#settings-btn{
  position:fixed;top:24px;right:24px;z-index:50;width:36px;height:36px;
  border-radius:50%;background:var(--glass);border:1.5px solid var(--border);
  color:var(--text-secondary);display:flex;align-items:center;justify-content:center;
  cursor:pointer;transition:all .3s;
}
#settings-btn:hover{border-color:rgba(255,255,255,.3);color:var(--text-primary);transform:rotate(45deg)}
#settings-btn svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}

#settings-panel{
  position:fixed;top:70px;right:24px;z-index:50;width:240px;
  background:var(--card-bg);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:20px;
  transform:translateX(120%);opacity:0;transition:all .4s cubic-bezier(.16,1,.3,1);
  pointer-events:none;
}
#settings-panel.open{transform:translateX(0);opacity:1;pointer-events:auto}
.setting-item{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.setting-item:last-child{margin-bottom:0}
.setting-label{font-size:.8rem;color:var(--text-secondary)}
.setting-toggle{
  width:36px;height:20px;border-radius:10px;background:rgba(255,255,255,.1);
  border:1px solid var(--border);cursor:pointer;position:relative;transition:all .3s;
}
.setting-toggle.on{background:var(--accent-purple);border-color:var(--accent-purple)}
.setting-toggle .st-knob{position:absolute;top:2px;left:2px;width:14px;height:14px;border-radius:50%;background:#fff;transition:all .3s cubic-bezier(.68,-.55,.27,1.55)}
.setting-toggle.on .st-knob{left:18px}
.setting-slider{width:80px;height:4px;border-radius:2px;background:rgba(255,255,255,.1);position:relative;cursor:pointer}
.setting-slider .st-fill{height:100%;border-radius:2px;background:var(--accent-purple);transition:width .2s}
.setting-slider .st-thumb{position:absolute;top:50%;width:12px;height:12px;border-radius:50%;background:#fff;transform:translate(-50%,-50%);transition:left .2s;box-shadow:0 1px 3px rgba(0,0,0,.3)}

/* ============================================
   16. CURSOR TRAIL
   ============================================ */
.cursor-dot{
  position:fixed;width:8px;height:8px;border-radius:50%;
  background:var(--accent-purple);pointer-events:none;z-index:9999;
  opacity:0;transition:opacity .3s;mix-blend-mode:screen;
  box-shadow:0 0 6px var(--accent-purple);
}

/* ============================================
   17. TOAST NOTIFICATIONS
   ============================================ */
#toast-container{position:fixed;bottom:24px;right:24px;z-index:200;display:flex;flex-direction:column;gap:10px}
.toast{
  padding:14px 20px;border-radius:var(--radius-xs);min-width:260px;
  background:var(--card-bg);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
  border:1px solid var(--border);color:var(--text-primary);font-size:.85rem;font-weight:500;
  transform:translateX(120%);opacity:0;transition:all .4s cubic-bezier(.16,1,.3,1);
  display:flex;align-items:center;gap:10px;
}
.toast.show{transform:translateX(0);opacity:1}
.toast-icon{width:20px;height:20px;flex-shrink:0;border-radius:50%;display:flex;align-items:center;justify-content:center}
.toast.success .toast-icon{background:rgba(52,211,153,.2);color:var(--success)}
.toast.error .toast-icon{background:rgba(248,113,113,.2);color:var(--error)}
.toast.info .toast-icon{background:rgba(96,165,250,.2);color:var(--accent-blue)}
.toast-icon svg{width:12px;height:12px;stroke:currentColor;fill:none;stroke-width:2.5}

/* ============================================
   18. CONFETTI CANVAS
   ============================================ */
#confetti-canvas{position:fixed;inset:0;z-index:150;pointer-events:none}

/* ============================================
   19. SUCCESS FLIP CARD
   ============================================ */
.card-outer.flipped .card{animation:none;transform:rotateY(180deg);backface-visibility:hidden}
.card-outer.flipped .card-success{
  position:absolute;inset:2px;border-radius:calc(var(--radius) - 2px);z-index:3;
  background:var(--card-bg);backdrop-filter:blur(var(--card-blur));-webkit-backdrop-filter:blur(var(--card-blur));
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  transform:rotateY(0);backface-visibility:hidden;
}
.card-success .check-circle{
  width:72px;height:72px;border-radius:50%;border:3px solid var(--success);
  display:flex;align-items:center;justify-content:center;margin-bottom:20px;
  animation:check-pop .5s cubic-bezier(.34,1.56,.64,1) .3s both;
}
@keyframes check-pop{0%{transform:scale(0);opacity:0}100%{transform:scale(1);opacity:1}}
.check-circle svg{width:32px;height:32px;stroke:var(--success);fill:none;stroke-width:3;stroke-linecap:round;stroke-linejoin:round;stroke-dasharray:50;stroke-dashoffset:50;animation:draw-check .6s ease .7s forwards}
@keyframes draw-check{to{stroke-dashoffset:0}}
.card-success h3{font-size:1.4rem;font-weight:700;margin-bottom:6px;opacity:0;animation:fade-up .5s ease .9s forwards}
.card-success p{font-size:.85rem;color:var(--text-secondary);opacity:0;animation:fade-up .5s ease 1.1s forwards}
@keyframes fade-up{to{opacity:1;transform:translateY(0)}from{opacity:0;transform:translateY(10px)}}

/* ============================================
   20. PAGE LOAD ANIMATIONS
   ============================================ */
.load-delay-1{transition-delay:.1s!important}
.load-delay-2{transition-delay:.2s!important}
.load-delay-3{transition-delay:.3s!important}
.load-delay-4{transition-delay:.4s!important}
.load-delay-5{transition-delay:.5s!important}

/* ============================================
   21. LIGHT MODE
   ============================================ */
body.light-mode{
  --bg-primary:#EEF2FF;--bg-secondary:#E0E7FF;--bg-tertiary:#C7D2FE;
  --card-bg:rgba(255,255,255,.65);--glass:rgba(0,0,0,.04);--glass-strong:rgba(0,0,0,.07);
  --border:rgba(0,0,0,.1);--border-focus:rgba(139,92,246,.5);
  --text-primary:#1E293B;--text-secondary:#475569;--text-muted:#94A3B8;
}
body.light-mode .aurora{opacity:.15}
body.light-mode .star{opacity:0!important}
body.light-mode .blob{opacity:.1}
body.light-mode .input-field{background:rgba(0,0,0,.03);border-color:rgba(0,0,0,.1)}
body.light-mode .input-field:hover{background:rgba(0,0,0,.05)}
body.light-mode .input-field:focus{background:rgba(0,0,0,.04)}
body.light-mode .custom-checkbox{background:rgba(0,0,0,.04);border-color:rgba(0,0,0,.15)}
body.light-mode .btn-social{background:rgba(0,0,0,.04);border-color:rgba(0,0,0,.1)}
body.light-mode .bunny-head,.body.light-mode .bunny-torso,.body.light-mode .bunny-ear,.body.light-mode .bunny-foot,.body.light-mode .bunny-tail{background:#F8FAFC}
body.light-mode .bunny-eye{background:#334155}
body.light-mode .bunny-nose{background:#F9A8D4}
body.light-mode .bunny-blush{background:rgba(251,182,206,.4)}
body.light-mode .bunny-speech{background:rgba(255,255,255,.8);border-color:rgba(0,0,0,.1);color:#1E293B}
body.light-mode .bunny-speech::after{border-top-color:rgba(0,0,0,.1)}
body.light-mode .mini-bunny .mb-body,.body.light-mode .mini-bunny .mb-ear{background:#F8FAFC}
body.light-mode .mini-bunny .mb-eye{background:#334155}

/* ============================================
   22. REDUCED MOTION
   ============================================ */
body.reduced-motion *,body.reduced-motion *::before,body.reduced-motion *::after{
  animation-duration:.01ms!important;animation-iteration-count:1!important;
  transition-duration:.15s!important;
}
body.reduced-motion .aurora,body.reduced-motion .blob,body.reduced-motion .star,body.reduced-motion .particle{display:none}

/* ============================================
   23. RESPONSIVE
   ============================================ */
@media(max-width:960px){
  .cards-container{flex-direction:column;align-items:center;gap:28px}
  .card{width:400px}
}
@media(max-width:480px){
  .card{width:92vw;padding:28px 20px}
  .logo{font-size:1.8rem}
