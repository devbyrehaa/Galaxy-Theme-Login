  #theme-toggle{right:64px;top:16px}
  #settings-btn{right:16px;top:16px}
  #settings-panel{right:12px;top:56px;width:220px}
  .social-btns{flex-direction:column}
}

/* ============================================
   24. RAINBOW MODE
   ============================================ */
body.rainbow-mode .btn-primary{background:linear-gradient(135deg,#ff0000,#ff8800,#ffff00,#00ff00,#0088ff,#8800ff);animation:rainbow-bg 2s linear infinite}
@keyframes rainbow-bg{to{filter:hue-rotate(360deg)}}
body.rainbow-mode .logo{background:linear-gradient(135deg,#ff0000,#ff8800,#ffff00,#00ff00,#0088ff,#8800ff);-webkit-background-clip:text;background-clip:text;animation:rainbow-bg 2s linear infinite}
body.rainbow-mode .aurora{opacity:.5!important}
body.rainbow-mode .blob{opacity:.3!important}

/* ============================================
