// ── Settings Panel ──
function initSettings() {
  const btn = document.getElementById('settings-btn');
  const panel = document.getElementById('settings-panel');
  let open = false;

  btn.addEventListener('click', () => {
    open = !open;
    panel.classList.toggle('open', open);
    Sound.init(); Sound.play('click');
  });

  // Close on outside click
  document.addEventListener('click', e => {
    if (open && !panel.contains(e.target) && !btn.contains(e.target)) {
      open = false; panel.classList.remove('open');
    }
  });

  // Sound toggle
  const sndToggle = document.getElementById('snd-toggle');
  sndToggle.addEventListener('click', () => {
    Sound.init();
    State.soundsEnabled = !State.soundsEnabled;
    sndToggle.classList.toggle('on', State.soundsEnabled);
    sndToggle.setAttribute('aria-checked', State.soundsEnabled);
    if (State.soundsEnabled) Sound.play('magic');
  });

  // Reduced motion toggle
  const rmToggle = document.getElementById('reduce-motion-toggle');
  rmToggle.addEventListener('click', () => {
    State.reducedMotion = !State.reducedMotion;
    rmToggle.classList.toggle('on', State.reducedMotion);
    rmToggle.setAttribute('aria-checked', State.reducedMotion);
    document.body.classList.toggle('reduced-motion', State.reducedMotion);
    Sound.init(); Sound.play('click');
  });

  // Animation speed slider
  initSlider('anim-speed-slider', v => {
    State.animSpeed = v / 50;
    document.documentElement.style.setProperty('--anim-speed', State.animSpeed);
  });

  // Bunny speed slider
  initSlider('bunny-speed-slider', v => { State.bunnySpeed = v / 50; });
}

function initSlider(id, onChange) {
  const slider = document.getElementById(id);
  const fill = slider.querySelector('.st-fill');
  const thumb = slider.querySelector('.st-thumb');
  let dragging = false;

  function update(clientX) {
    const rect = slider.getBoundingClientRect();
    let pct = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
    fill.style.width = thumb.style.left = (pct * 100) + '%';
    slider.setAttribute('aria-valuenow', Math.round(pct * 100));
    onChange(pct * 100);
  }

  slider.addEventListener('mousedown', e => { dragging = true; update(e.clientX); });
  document.addEventListener('mousemove', e => { if (dragging) update(e.clientX); });
  document.addEventListener('mouseup', () => { dragging = false; });
  slider.addEventListener('touchstart', e => { dragging = true; update(e.touches[0].clientX); }, { passive: true });
  document.addEventListener('touchmove', e => { if (dragging) update(e.touches[0].clientX); }, { passive: true });
  document.addEventListener('touchend', () => { dragging = false; });
}

// ── Toast System ──
function showToast(message, type = 'info') {
  const container = document.getElementById('toast-container');
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  const icons = {
    success: '<svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>',
    error: '<svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>',
    info: '<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>'
  };
  toast.innerHTML = `<div class="toast-icon">${icons[type]}</div><span>${message}</span>`;
  container.appendChild(toast);
  requestAnimationFrame(() => toast.classList.add('show'));
  setTimeout(() => {
    toast.classList.remove('show');
    setTimeout(() => toast.remove(), 400);
  }, 3500);
}

// ── Confetti System ──
function launchConfetti(duration = 3000) {
  const canvas = document.getElementById('confetti-canvas');
  const ctx = canvas.getContext('2d');
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
  const pieces = [];
  const colors = ['#8B5CF6', '#EC4899', '#60A5FA', '#22D3EE', '#FBBF24', '#34D399', '#F472B6', '#A855F7'];

  for (let i = 0; i < 120; i++) {
    pieces.push({
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height - canvas.height,
      w: Math.random() * 8 + 4,
      h: Math.random() * 6 + 3,
      color: colors[Math.floor(Math.random() * colors.length)],
      vx: (Math.random() - 0.5) * 4,
      vy: Math.random() * 3 + 2,
      rot: Math.random() * 360,
      rotV: (Math.random() - 0.5) * 10,
      opacity: 1
    });
  }

  const start = Date.now();
  function draw() {
    const elapsed = Date.now() - start;
    if (elapsed > duration) { ctx.clearRect(0, 0, canvas.width, canvas.height); return; }
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    pieces.forEach(p => {
      p.x += p.vx;
      p.y += p.vy;
      p.vy += 0.05;
      p.rot += p.rotV;
      if (elapsed > duration * 0.7) p.opacity = Math.max(0, 1 - (elapsed - duration * 0.7) / (duration * 0.3));
      ctx.save();
      ctx.translate(p.x, p.y);
      ctx.rotate(p.rot * Math.PI / 180);
      ctx.globalAlpha = p.opacity;
      ctx.fillStyle = p.color;
      ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
      ctx.restore();
    });
    requestAnimationFrame(draw);
  }
  draw();
}

// ── Form Handling ──
function initForms() {
  // Live validation on blur
  document.querySelectorAll('.input-group[data-field]').forEach(group => {
    const input = group.querySelector('.input-field');
    input.addEventListener('blur', () => {
      if (input.value) validateField(group, input.value);
    });
    input.addEventListener('input', () => {
      if (group.dataset.field === 'password') updateStrength(input.value);
      if (group.classList.contains('error') || group.classList.contains('success')) {
        validateField(group, input.value);
      }
    });
  });

  // Signup form
  document.getElementById('signup-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    Sound.init();
    const fields = ['s-name', 's-email', 's-password', 's-confirm'];
    let valid = true;

    fields.forEach(id => {
      const input = document.getElementById(id);
      const group = input.closest('.input-group');
      if (!validateField(group, input.value)) {
        valid = false;
        group.classList.add('shake');
        setTimeout(() => group.classList.remove('shake'), 500);
      }
    });

    if (!document.getElementById('terms-check').classList.contains('checked')) {
      showToast('Please accept the Terms of Service', 'error');
      return;
    }

    if (!valid) { Sound.play('click'); return; }

    // Success flow
    const btn = document.getElementById('signup-btn');
    btn.classList.add('loading');
    btn.disabled = true;

    await new Promise(r => setTimeout(r, 1800));
    Sound.play('success');

    // Flip card
    const outer = document.getElementById('signup-outer');
    outer.style.transition = 'transform .8s cubic-bezier(.4,0,.2,1)';
    outer.style.transformStyle = 'preserve-3d';
    outer.style.perspective = '1000px';
    outer.querySelector('.card').style.transition = 'transform .8s cubic-bezier(.4,0,.2,1)';
    outer.querySelector('.card').style.transform = 'rotateY(180deg)';
    outer.querySelector('.card').style.backfaceVisibility = 'hidden';

    const successEl = outer.querySelector('.card-success');
    successEl.style.display = 'flex';
    successEl.style.transform = 'rotateY(0)';
    successEl.style.backfaceVisibility = 'hidden';

    launchConfetti(4000);
    showToast('Account created successfully!', 'success');
  });

  // Login form
  document.getElementById('login-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    Sound.init();
    const fields = ['l-email', 'l-password'];
    let valid = true;

    fields.forEach(id => {
      const input = document.getElementById(id);
      const group = input.closest('.input-group');
      if (!validateField(group, input.value)) {
        valid = false;
        group.classList.add('shake');
        setTimeout(() => group.classList.remove('shake'), 500);
      }
    });

    if (!valid) { Sound.play('click'); return; }

    const btn = document.getElementById('login-btn');
    btn.classList.add('loading');
    btn.disabled = true;

    await new Promise(r => setTimeout(r, 2000));
    Sound.play('success');
    btn.classList.remove('loading');
    btn.querySelector('.btn-text').textContent = '';
    btn.innerHTML = `<span class="btn-text" style="display:flex;align-items:center;justify-content:center;gap:8px">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      Success
    </span>`;
    btn.style.background = 'linear-gradient(135deg, #059669, #34D399)';
    btn.style.boxShadow = '0 0 40px rgba(52,211,153,.4)';
    showToast('Welcome back! Login successful.', 'success');

    // Reset after 3s
    setTimeout(() => {
      btn.disabled = false;
      btn.innerHTML = '<span class="btn-text">Login</span><div class="btn-loader"><div class="spinner"></div></div>';
      btn.style.background = '';
      btn.style.boxShadow = '';
    }, 3000);
  });
}

// ── Easter Eggs ──
function initEasterEggs() {
  // "bunny" text easter egg
  let bunnyBuffer = '';
  document.addEventListener('input', (e) => {
    if (e.target.tagName !== 'INPUT') return;
    bunnyBuffer += e.data || '';
    if (bunnyBuffer.length > 10) bunnyBuffer = bunnyBuffer.slice(-10);
    if (bunnyBuffer.toLowerCase().includes('bunny') && !State.bunnyEasterEggActive) {
      State.bunnyEasterEggActive = true;
      bunnyBuffer = '';
      spawnMiniBunnies();
      setTimeout(() => { State.bunnyEasterEggActive = false; }, 5000);
    }
  });

  // Konami code
  const konamiSequence = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
  document.addEventListener('keydown', (e) => {
    State.konamiBuffer.push(e.key);
    if (State.konamiBuffer.length > konamiSequence.length) State.konamiBuffer.shift();
    if (State.konamiBuffer.length === konamiSequence.length &&
        State.konamiBuffer.every((k, i) => k === konamiSequence[i])) {
      State.konamiBuffer = [];
      activateRainbowMode();
    }
  });
}

function spawnMiniBunnies() {
  Sound.init(); Sound.play('magic');
  const count = 8;
  for (let i = 0; i < count; i++) {
    const mb = document.createElement('div');
    mb.className = 'mini-bunny';
    mb.innerHTML = '<div class="mb-body"><div class="mb-ear l"></div><div class="mb-ear r"></div><div class="mb-eye l"></div><div class="mb-eye r"></div></div>';
    mb.style.left = Math.random() * (window.innerWidth - 30) + 'px';
    mb.style.top = Math.random() * (window.innerHeight - 30) + 'px';
    document.body.appendChild(mb);
    State.miniBunnies.push(mb);
    animateMiniBunny(mb);
  }
  setTimeout(() => {
    State.miniBunnies.forEach(mb => { mb.style.opacity = '0'; mb.style.transition = 'opacity .5s'; setTimeout(() => mb.remove(), 500); });
    State.miniBunnies = [];
  }, 4500);
}

function animateMiniBunny(mb) {
  let x = parseFloat(mb.style.left), y = parseFloat(mb.style.top);
  let vx = (Math.random() - 0.5) * 4, vy = (Math.random() - 0.5) * 4;
  function move() {
    if (!mb.parentElement) return;
    x += vx; y += vy;
    if (x < 0 || x > window.innerWidth - 20) vx *= -1;
    if (y < 0 || y > window.innerHeight - 20) vy *= -1;
    mb.style.left = x + 'px';
    mb.style.top = y + 'px';
    mb.style.transform = `scaleX(${vx > 0 ? 1 : -1})`;
    requestAnimationFrame(move);
  }
  move();
}

function activateRainbowMode() {
  Sound.init(); Sound.play('magic');
  State.rainbowMode = !State.rainbowMode;
  document.body.classList.toggle('rainbow-mode', State.rainbowMode);
  if (State.rainbowMode) {
    launchConfetti(5000);
    showToast('Rainbow Mode Activated!', 'success');
  }
}

// ── Page Load Sequence ──
async function pageLoadSequence() {
  // Step 1: Background fades in (CSS handles this)
  await delay(300);

  // Step 2: Header
  document.getElementById('page-header').classList.add('visible');
  await delay(400);

  // Step 3: Cards
  document.querySelectorAll('.card-outer').forEach(c => c.classList.add('visible'));
  document.getElementById('cards-container').classList.add('visible');
  await delay(600);

  // Step 4: Typing animation
  const headings = document.querySelectorAll('.card-heading');
  await Promise.all([...headings].map(h => typeText(h, h.dataset.text, 65)));
}

function delay(ms) { return new Promise(r => setTimeout(r, ms)); }

// ── Window Resize Handler ──
function initResize() {
  window.addEventListener('resize', () => {
    const canvas = document.getElementById('confetti-canvas');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  });
}

// ── Initialize Everything ──
function init() {
  generateStars();
  initParticles();
  initParallax();
  initCursorTrail();
  initCardTilt();
  initPasswordToggles();
  initCheckboxes();
  initButtons();
  initBunny();
  initBunnySpeech();
  initBunnyCardInteraction();
  initThemeToggle();
  initSettings();
  initForms();
  initEasterEggs();
  initResize();
  pageLoadSequence();
}

// Start when DOM is ready
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', init);
} else {
  init();
}
