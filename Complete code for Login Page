<script>
/* ============================================
   AURORA AUTH - MAIN SCRIPT
   ============================================ */

// ── Global State ──
const State = {
  mouse: { x: window.innerWidth / 2, y: window.innerHeight / 2 },
  soundsEnabled: false,
  animSpeed: 1,
  reducedMotion: false,
  bunnySpeed: 1,
  audioCtx: null,
  konamiBuffer: [],
  rainbowMode: false,
  bunnyEasterEggActive: false,
  miniBunnies: []
};

// ── Sound System (Web Audio API) ──
const Sound = {
  init() {
    if (State.audioCtx) return;
    State.audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  },
  play(type) {
    if (!State.soundsEnabled || !State.audioCtx) return;
    if (State.audioCtx.state === 'suspended') State.audioCtx.resume();
    const ctx = State.audioCtx;
    const now = ctx.currentTime;
    const gain = ctx.createGain();
    gain.connect(ctx.destination);

    if (type === 'click') {
      const osc = ctx.createOscillator();
      osc.type = 'sine'; osc.frequency.setValueAtTime(800, now);
      osc.frequency.exponentialRampToValueAtTime(400, now + 0.08);
      gain.gain.setValueAtTime(0.1, now);
      gain.gain.exponentialRampToValueAtTime(0.001, now + 0.1);
      osc.connect(gain); osc.start(now); osc.stop(now + 0.1);
    } else if (type === 'bubble') {
      const osc = ctx.createOscillator();
      osc.type = 'sine'; osc.frequency.setValueAtTime(300, now);
      osc.frequency.exponentialRampToValueAtTime(1200, now + 0.15);
      gain.gain.setValueAtTime(0.08, now);
      gain.gain.exponentialRampToValueAtTime(0.001, now + 0.18);
      osc.connect(gain); osc.start(now); osc.stop(now + 0.18);
    } else if (type === 'magic') {
      [523, 659, 784].forEach((f, i) => {
        const osc = ctx.createOscillator();
        const g = ctx.createGain();
        osc.type = 'sine'; osc.frequency.value = f;
        g.gain.setValueAtTime(0.06, now + i * 0.08);
        g.gain.exponentialRampToValueAtTime(0.001, now + i * 0.08 + 0.3);
        osc.connect(g); g.connect(ctx.destination);
        osc.start(now + i * 0.08); osc.stop(now + i * 0.08 + 0.3);
      });
    } else if (type === 'success') {
      [523, 659, 784, 1047].forEach((f, i) => {
        const osc = ctx.createOscillator();
        const g = ctx.createGain();
        osc.type = 'triangle'; osc.frequency.value = f;
        g.gain.setValueAtTime(0.08, now + i * 0.12);
        g.gain.exponentialRampToValueAtTime(0.001, now + i * 0.12 + 0.4);
        osc.connect(g); g.connect(ctx.destination);
        osc.start(now + i * 0.12); osc.stop(now + i * 0.12 + 0.4);
      });
    }
  }
};

// ── Star Generation ──
function generateStars() {
  const container = document.getElementById('stars-container');
  const count = 130;
  for (let i = 0; i < count; i++) {
    const star = document.createElement('div');
    star.className = 'star';
    const size = Math.random() * 2.5 + 0.5;
    star.style.cssText = `
      width:${size}px;height:${size}px;
      top:${Math.random() * 100}%;left:${Math.random() * 100}%;
      animation:twinkle ${Math.random() * 3 + 2}s ease-in-out ${Math.random() * 5}s infinite;
    `;
    container.appendChild(star);
  }
}

// ── Floating Particles ──
function spawnParticle() {
  if (State.reducedMotion) return;
  const container = document.getElementById('particles-container');
  const p = document.createElement('div');
  p.className = 'particle';
  const size = Math.random() * 4 + 2;
  const colors = ['#8B5CF6', '#EC4899', '#60A5FA', '#22D3EE', '#A855F7'];
  const color = colors[Math.floor(Math.random() * colors.length)];
  const dur = Math.random() * 12 + 8;
  p.style.cssText = `
    width:${size}px;height:${size}px;
    left:${Math.random() * 100}%;bottom:-10px;
    background:${color};box-shadow:0 0 ${size * 2}px ${color};
    animation:float-up ${dur}s linear ${Math.random() * dur}s infinite;
  `;
  container.appendChild(p);
}
function initParticles() {
  for (let i = 0; i < 15; i++) spawnParticle();
}

// ── Mouse Parallax ──
function initParallax() {
  document.addEventListener('mousemove', (e) => {
    State.mouse.x = e.clientX;
    State.mouse.y = e.clientY;
    const cx = (e.clientX / window.innerWidth - 0.5) * 2;
    const cy = (e.clientY / window.innerHeight - 0.5) * 2;
    document.querySelectorAll('.aurora').forEach((a, i) => {
      const f = (i + 1) * 8;
      a.style.transform = `translate(${cx * f}px, ${cy * f}px)`;
    });
    document.querySelectorAll('.blob').forEach((b, i) => {
      const f = (i + 1) * 5;
      b.style.transform = `translate(${cx * f}px, ${cy * f}px)`;
    });
  });
}

// ── Cursor Trail ──
function initCursorTrail() {
  if ('ontouchstart' in window) return;
  const container = document.getElementById('cursor-trail');
  const dots = [];
  const maxDots = 12;
  for (let i = 0; i < maxDots; i++) {
    const dot = document.createElement('div');
    dot.className = 'cursor-dot';
    dot.style.opacity = '0';
    container.appendChild(dot);
    dots.push({ el: dot, x: 0, y: 0 });
  }
  let mx = 0, my = 0;
  document.addEventListener('mousemove', (e) => { mx = e.clientX; my = e.clientY; });
  function animate() {
    let px = mx, py = my;
    dots.forEach((d, i) => {
      const speed = 0.35 - i * 0.02;
      d.x += (px - d.x) * speed;
      d.y += (py - d.y) * speed;
      d.el.style.left = d.x - 4 + 'px';
      d.el.style.top = d.y - 4 + 'px';
      d.el.style.opacity = (1 - i / maxDots) * 0.5;
      d.el.style.width = d.el.style.height = Math.max(2, 8 - i * 0.5) + 'px';
      px = d.x; py = d.y;
    });
    requestAnimationFrame(animate);
  }
  animate();
}

// ── Card Tilt Effect ──
function initCardTilt() {
  document.querySelectorAll('.card').forEach(card => {
    card.addEventListener('mousemove', (e) => {
      if (State.reducedMotion) return;
      const rect = card.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      card.style.transform = `translateY(${parseFloat(getComputedStyle(card).transform.split(',')[5]) || 0}px) perspective(800px) rotateX(${-y * 6}deg) rotateY(${x * 6}deg)`;
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = '';
    });
  });
}

// ── Typing Animation ──
function typeText(el, text, speed = 70) {
  return new Promise(resolve => {
    const span = el.querySelector('.typed-text');
    const cursor = el.querySelector('.cursor');
    let i = 0;
    span.textContent = '';
    function tick() {
      if (i < text.length) {
        span.textContent += text[i++];
        Sound.play('click');
        setTimeout(tick, speed / State.animSpeed);
      } else {
        setTimeout(() => { cursor.style.display = 'none'; resolve(); }, 1200);
      }
    }
    tick();
  });
}

// ── Input Validation ──
function validateField(group, value) {
  const field = group.dataset.field;
  const msg = group.querySelector('.validation-msg');
  group.classList.remove('error', 'success', 'shake');

  if (field === 'name') {
    if (value.length < 2) { group.classList.add('error'); msg.textContent = 'Name must be at least 2 characters'; return false; }
    group.classList.add('success'); msg.textContent = 'Looks good!'; return true;
  }
  if (field === 'email') {
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)) { group.classList.add('error'); msg.textContent = 'Enter a valid email address'; return false; }
    group.classList.add('success'); msg.textContent = 'Valid email!'; return true;
  }
  if (field === 'password') {
    if (value.length < 8) { group.classList.add('error'); msg.textContent = 'At least 8 characters required'; return false; }
    group.classList.add('success'); msg.textContent = 'Strong password!'; return true;
  }
  if (field === 'confirm') {
    const pwd = document.getElementById('s-password').value;
    if (value !== pwd) { group.classList.add('error'); msg.textContent = 'Passwords do not match'; return false; }
    if (!value) { group.classList.add('error'); msg.textContent = 'Please confirm your password'; return false; }
    group.classList.add('success'); msg.textContent = 'Passwords match!'; return true;
  }
  return true;
}

// ── Password Strength Meter ──
function updateStrength(value) {
  const meter = document.querySelector('.strength-meter');
  const bar = meter.querySelector('.strength-bar');
  const label = document.querySelector('.strength-label');
  if (!value) { meter.classList.remove('visible'); return; }
  meter.classList.add('visible');

  let score = 0;
  if (value.length >= 8) score++;
  if (value.length >= 12) score++;
  if (/[A-Z]/.test(value)) score++;
  if (/[a-z]/.test(value)) score++;
  if (/[0-9]/.test(value)) score++;
  if (/[^A-Za-z0-9]/.test(value)) score++;

  const levels = [
    { max: 2, w: '20%', label: 'Weak', color: '#F87171' },
    { max: 3, w: '45%', label: 'Medium', color: '#FBBF24' },
    { max: 5, w: '75%', label: 'Strong', color: '#34D399' },
    { max: 6, w: '100%', label: 'Very Strong', color: '#22D3EE' }
  ];
  const level = levels.find(l => score <= l.max) || levels[3];
  bar.style.width = level.w;
  bar.style.background = `linear-gradient(90deg, ${level.color}88, ${level.color})`;
  label.textContent = level.label;
  label.style.color = level.color;
}

// ── Password Toggle ──
function initPasswordToggles() {
  document.querySelectorAll('.pwd-toggle').forEach(btn => {
    function toggle() {
      Sound.init();
      const input = document.getElementById(btn.dataset.target);
      const isOpen = input.type === 'password';
      btn.classList.add('wink');
      setTimeout(() => btn.classList.remove('wink'), 300);
      setTimeout(() => {
        input.type = isOpen ? 'text' : 'password';
        btn.querySelector('.eye-open').style.display = isOpen ? 'none' : 'block';
        btn.querySelector('.eye-closed').style.display = isOpen ? 'block' : 'none';
        Sound.play('bubble');
      }, 150);
    }
    btn.addEventListener('click', toggle);
    btn.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); }});
  });
}

// ── Checkbox Toggle ──
function initCheckboxes() {
  document.querySelectorAll('.checkbox-group').forEach(cb => {
    function toggle() {
      Sound.init();
      const checked = cb.classList.toggle('checked');
      cb.setAttribute('aria-checked', checked);
      cb.classList.add('bounce');
      setTimeout(() => cb.classList.remove('bounce'), 400);
      Sound.play('click');
    }
    cb.addEventListener('click', toggle);
    cb.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); }});
  });
}

// ── Button Effects ──
function initButtons() {
  document.querySelectorAll('.btn-primary, .btn-social').forEach(btn => {
    // Ripple effect
    btn.addEventListener('click', function(e) {
      Sound.init();
      const rect = this.getBoundingClientRect();
      const ripple = document.createElement('span');
      ripple.className = 'ripple';
      const size = Math.max(rect.width, rect.height);
      ripple.style.width = ripple.style.height = size + 'px';
      ripple.style.left = e.clientX - rect.left - size / 2 + 'px';
      ripple.style.top = e.clientY - rect.top - size / 2 + 'px';
      this.appendChild(ripple);
      setTimeout(() => ripple.remove(), 600);
      Sound.play('click');
    });

    // Magnetic hover
    btn.addEventListener('mousemove', function(e) {
      if (State.reducedMotion) return;
      const rect = this.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      this.style.transform = `translate(${x * 0.15}px, ${y * 0.15}px)`;
    });
    btn.addEventListener('mouseleave', function() { this.style.transform = ''; });
  });
}

// ── Bunny Movement (walks around login card border) ──
function initBunny() {
  const bunny = document.getElementById('bunny');
  const loginOuter = document.getElementById('login-outer');
  let progress = 0;
  let currentRotation = 0;

  function getPosition(p, rect) {
    const w = rect.width, h = rect.height;
    const perim = 2 * (w + h);
    const dist = p * perim;
    let x, y, rot;

    if (dist < w) {
      // Top edge: left to right
      x = dist; y = -22; rot = 0;
    } else if (dist < w + h) {
      // Right edge: top to bottom
      x = w + 10; y = dist - w; rot = 90;
    } else if (dist < 2 * w + h) {
      // Bottom edge: right to left
      x = w - (dist - w - h); y = h + 2; rot = 180;
    } else {
      // Left edge: bottom to top
      x = -10; y = h - (dist - 2 * w - h); rot = -90;
    }
    return { x, y, rot };
  }

  function animate() {
    const rect = loginOuter.getBoundingClientRect();
    const containerRect = document.getElementById('cards-container').getBoundingClientRect();
    const pos = getPosition(progress, { width: rect.width, height: rect.height });

    const bx = rect.left - containerRect.left + pos.x;
    const by = rect.top - containerRect.top + pos.y;
    bunny.style.left = bx + 'px';
    bunny.style.top = by + 'px';

    // Smooth rotation
    let diff = pos.rot - currentRotation;
    if (diff > 180) diff -= 360;
    if (diff < -180) diff += 360;
    currentRotation += diff * 0.1;
    bunny.querySelector('.bunny-wrap').style.transform = `rotate(${currentRotation}deg)`;

    // Scale X to flip bunny based on direction
    const scaleX = (currentRotation > 90 || currentRotation < -90) ? -1 : 1;
    bunny.querySelector('.bunny-wrap').style.transform = `rotate(${currentRotation}deg) scaleX(${Math.abs(currentRotation % 360) > 90 && Math.abs(currentRotation % 360) < 270 ? -1 : 1})`;

    const speed = (0.0003 * State.bunnySpeed) / State.animSpeed;
    progress = (progress + speed) % 1;
    requestAnimationFrame(animate);
  }
  animate();
}

// ── Bunny Speech ──
function initBunnySpeech() {
  const bunny = document.getElementById('bunny');
  const speech = document.getElementById('bunny-speech');
  const phrases = ['Hello!', 'Welcome!', "Let's Go!", 'Good Luck!', 'Nice to see you!', 'Hi there!', 'You look great!', 'Stay awesome!'];
  let speechInterval;

  function showSpeech() {
    speech.textContent = phrases[Math.floor(Math.random() * phrases.length)];
    speech.classList.add('show');
    setTimeout(() => speech.classList.remove('show'), 2500);
  }

  function scheduleSpeech() {
    speechInterval = setTimeout(() => {
      showSpeech();
      scheduleSpeech();
    }, Math.random() * 5000 + 4000);
  }
  scheduleSpeech();

  // Hover: hearts
  bunny.addEventListener('mouseenter', () => {
    showSpeech();
    for (let i = 0; i < 6; i++) {
      setTimeout(() => spawnHeart(bunny), i * 100);
    }
  });
}

function spawnHeart(parent) {
  const heart = document.createElement('div');
  heart.className = 'heart-particle';
  heart.textContent = '\u2764';
  heart.style.cssText = `left:${Math.random() * 30}px;bottom:20px;--hx:${(Math.random() - 0.5) * 40}px;--hr:${(Math.random() - 0.5) * 60}deg;color:${['#EC4899','#F472B6','#FB7185','#FBB6CE'][Math.floor(Math.random()*4)]}`;
  parent.appendChild(heart);
  setTimeout(() => heart.remove(), 1200);
}

